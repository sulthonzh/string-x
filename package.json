{
  "name": "string-x-utils",
  "version": "1.1.0",
  "description": "Zero-dependency string manipulation utilities — case conversion, trimming, padding, templates, slugify, HTML escaping, and more.",
  "type": "module",
  "main": "index.js",
  "exports": {
    ".": {
      "import": "./index.js",
      "require": "./index.js"
    }
  },
  "bin": {
    "string-x-utils": "cli.js"
  },
  "files": [
    "index.js",
    "cli.js",
    "README.md",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "test": "node --test test.js",
    "test:core": "node --test test.js",
    "test:coverage": "c8 --reporter=text node --test test.js",
    "prepublishOnly": "npm test"
  },
  "devDependencies": {
    "c8": "^11.0.0",
    "eslint": "^10.6.0",
    "globals": "^17.7.0"
  },
  "keywords": [
    "string",
    "case",
    "camelCase",
    "snake_case",
    "kebab-case",
    "slugify",
    "template",
    "escape",
    "truncate",
    "zero-dependency"
  ],
  "author": "sulthonzh",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sulthonzh/string-x"
  },
  "homepage": "https://github.com/sulthonzh/string-x#readme",
  "bugs": {
    "url": "https://github.com/sulthonzh/string-x/issues"
  }
}
